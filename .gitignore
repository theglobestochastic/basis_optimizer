# === GlobeStochastic Node
venv/
.venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- NVIDIA CUDA & Compiled Binaries ---
# Ignore compiled object files and GPU-specific artifacts
*.o
*.obj
*.lib
*.a
*.exp
*.res
*.cu.o
*.ptx
*.cubin
*.fatbin

# --- LaTeX & Tectonic ---
# Tectonic is clean, but LaTeX still generates auxiliary files.
*.aux
*.log
*.toc
*.out
*.fdb_latexmk
*.fls
*.synctex.gz
*.pdfsync
*.blg
*.bbl
# NOTE: If you want to commit your final whitepapers, 
# keep 'reports/*.pdf' but ignore root-level PDFs.
/*.pdf

# --- Data & Security (CRITICAL) ---
# Never commit raw datasets or private keys.
data/*.csv
data/*.parquet
data/*.json
.env
.secrets
*.key
*.pem

# --- Arch Linux & System Files ---
# Avoid OS-specific clutter
.DS_Store
Thumbs.db
*~
*.swp
*.bak
.directory
